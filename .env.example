# ────────── Local admin auth ──────────
# Choose any strong password — this is your local login.
ADMIN_PASSWORD=change-me-now

# Secret used to sign the session cookie. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Optional — shows up in the sidebar
ADMIN_EMAIL=

# ────────── AI providers ──────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Optional model overrides
ANTHROPIC_OUTLINE_MODEL=claude-opus-4-6
ANTHROPIC_LESSON_MODEL=claude-sonnet-4-6
ANTHROPIC_EXTRACT_MODEL=claude-sonnet-4-6
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# ────────── App ──────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ────────── Local data ──────────
# Where the SQLite file and uploaded PDFs live. Defaults to ./.local-data
# COURSE_FACTORY_DATA_DIR=./.local-data
